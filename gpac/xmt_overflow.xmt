<?xml version="1.0" encoding="UTF-8" ?>
<XMT-A xmlns="urn:mpeg:mpeg4:xmta:schema:2002">
 <Header>
  <InitialObjectDescriptor objectDescriptorID="1" binaryID="1">
   <Profiles ODProfileLevelIndication="1" sceneProfileLevelIndication="1"
             audioProfileLevelIndication="255" visualProfileLevelIndication="1"
             graphicsProfileLevelIndication="1" />
   <Descr>
    <esDescr>
     <ES_Descriptor ES_ID="1" OCR_ES_ID="1">
      <decConfigDescr>
       <DecoderConfigDescriptor streamType="3" objectTypeIndication="2"/>
      </decConfigDescr>
      <slConfigDescr><SLConfigDescriptor><custom timeStampResolution="1000"/></SLConfigDescriptor></slConfigDescr>
     </ES_Descriptor>
    </esDescr>
   </Descr>
  </InitialObjectDescriptor>
 </Header>
 <Body>
  <Replace>
   <Scene>
    <Group>
     <children>
      <ProtoDeclare name="TestProto">
       <ProtoInterface>
        <field name="testField" type="" accessType="inputOutput"/>
       </ProtoInterface>
       <ProtoBody><WorldInfo/></ProtoBody>
      </ProtoDeclare>
     </children>
    </Group>
   </Scene>
  </Replace>
 </Body>
</XMT-A>